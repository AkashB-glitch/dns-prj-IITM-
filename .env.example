# ─────────────────────────────────────────────────────────────────────────────
# DNS Exposure Monitor — Environment Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit the filled .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Twilio ────────────────────────────────────────────────────────────────────
# Your Twilio Account SID (starts with AC...)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio Auth Token
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio WhatsApp Sandbox sender number (default sandbox number shown)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Admin's WhatsApp number to receive alerts (include country code)
ADMIN_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# ── Scanner ───────────────────────────────────────────────────────────────────
# HTTP request timeout in seconds
REQUEST_TIMEOUT=10

# Number of automatic retries on connection errors
REQUEST_RETRIES=3

# ── Scheduler ─────────────────────────────────────────────────────────────────
# How often (in hours) to scan all URLs
SCAN_INTERVAL_HOURS=6

# ── Lifecycle thresholds ──────────────────────────────────────────────────────
# Retest count before escalation
ESCALATION_RETEST_LIMIT=3

# Hours since first detection before time-based escalation
ESCALATION_HOURS=48

# ── Paths ─────────────────────────────────────────────────────────────────────
DB_PATH=dns_monitor.db
URL_FILE=iitm_urls.txt
LOG_FILE=dns_monitor.log
